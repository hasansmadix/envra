{
  "name": "@envra/eslint-plugin",
  "version": "0.1.0",
  "description": "ESLint plugin for envra (no direct process.env)",
  "keywords": [
    "eslint",
    "eslintplugin",
    "environment-variables",
    "typescript",
    "envra"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hasansmadix/envra.git",
    "directory": "packages/eslint-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "picomatch": "^4.0.2"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "~5.7.2",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "eslint": ">=8.57.0"
  }
}
